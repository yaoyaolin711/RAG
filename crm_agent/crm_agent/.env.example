# CRM Agent — DeepSeek
# 方式一：环境变量
DEEPSEEK_KEY=your_deepseek_api_key_here
# 方式二：密钥文件（默认 D:\DEEPSEEK_KEY.txt，仅写一行密钥即可）
# DEEPSEEK_KEY_FILE=D:\DEEPSEEK_KEY.txt

LLM_MODEL_NAME=deepseek-chat
LLM_MODEL_BASE_URL=https://api.deepseek.com/v1

# 向量库与 Embedding（默认使用本机路径，可按需修改）
MILVUS_PATH=D:\Milvus
MILVUS_URI=D:\Milvus\milvus.db
BGE_M3_PATH=D:\BGE-M3
BGE_M3_DEVICE=cpu

# 可选
EXPORT_DB_PATH=
CRM_AGENT_CONFIG_DIR=
API_PORT=7120
